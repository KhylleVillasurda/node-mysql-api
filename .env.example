# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
# LOCAL DEV — use these when running locally
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=node_boilerplate_api

# RAILWAY — when you add the MySQL addon, Railway automatically injects:
#   MYSQL_URL, MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE
# You do NOT need to set DB_* vars on Railway; they are ignored when MYSQL_URL is present.

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ─── Email ────────────────────────────────────────────────────────────────────
# Choose your provider: gmail | resend
EMAIL_PROVIDER=gmail
EMAIL_FROM=noreply@yourdomain.com

# Gmail — use an App Password, NOT your account password.
# Steps: enable 2FA → https://myaccount.google.com/apppasswords → generate
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Resend (free: 3,000/mo, 100/day) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── CORS (production only) ───────────────────────────────────────────────────
# Comma-separated list of allowed origins, e.g.:
# CORS_ORIGIN=https://myapp.com,https://www.myapp.com
CORS_ORIGIN=
